<script>
$(".dropdown" ).hover(function(){$(this).addClass("select")},
function(){$(this).removeClass("select")
});
</script>
<script>
$(function(){
    $('#top').click(function () {
    $('body,html').animate({
      scrollTop: 0
      }, 600);
      return false;
  });
  $(window).scroll(function () {
    if ($(this).scrollTop() > 15) {
    $('.totop a').fadeIn(500);
    } else {
    $('.totop a').fadeOut(500);
    }
  });
});
</script>
<script>
 $(document).ready(function() {
    $("video").bind("contextmenu",function(){
        return false;
        });
 } );
 </script>

