.green{position:fixed;right:-1px;top:110px;-webkit-transform:translate(0, -50%);-ms-transform:translate(0, -50%);transform:translate(0, -50%);cursor:pointer;border:0;background:none;padding:0;z-index:999;width:50px;-webkit-transition:.5s;-o-transition:.5s;transition:.5s}.green.active{right:333px;-webkit-transition:.5s;-o-transition:.5s;transition:.5s}

.isa{position:fixed;right:-1px;top:160px;-webkit-transform:translate(0, -50%);-ms-transform:translate(0, -50%);transform:translate(0, -50%);cursor:pointer;border:0;background:none;padding:0;z-index:999;width:50px;-webkit-transition:.5s;-o-transition:.5s;transition:.5s}.isa.active{right:333px;-webkit-transition:.5s;-o-transition:.5s;transition:.5s}

.surdurulebilirs{position:fixed;right:-1px;top:210px;-webkit-transform:translate(0, -50%);-ms-transform:translate(0, -50%);transform:translate(0, -50%);cursor:pointer;border:0;background:none;padding:0;z-index:999;width:50px;-webkit-transition:.5s;-o-transition:.5s;transition:.5s}.surdurulebilirs.active{right:333px;-webkit-transition:.5s;-o-transition:.5s;transition:.5s}


