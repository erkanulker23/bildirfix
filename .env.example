APP_NAME=simdibildir.com
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://simdibildir.com
# Üretim (Forge): APP_ENV=production, APP_DEBUG=false, FORCE_HTTPS=true
FORCE_HTTPS=false
APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

# Canonical, yapısal veri, OG/Twitter; üretimde SEO_DEFAULT_ROBOTS boş bırakılırsa APP_ENV'e göre belirlenir
SEO_DEFAULT_DESCRIPTION=
SEO_DEFAULT_ROBOTS=
SEO_OG_IMAGE=
SEO_ORG_NAME=simdibildir.com
SEO_OG_LOCALE=tr_TR
SEO_FONT_PRECONNECT_HOSTS=https://fonts.bunny.net

# --- Laravel Forge ---
# Deploy: bash scripts/forge-deploy.sh  (veya DEPLOY.md)
# İlk kurulum (bir kez): bash scripts/forge-bootstrap.sh
# SCHEDULER: * * * * * cd $FORGE_SITE_PATH && php artisan schedule:run
# QUEUE (redis): php artisan queue:work redis --sleep=3 --tries=3

LOCALES=tr

IS_DEMO=false
BACKUP_ENABLED=false
BACKUP_DISK=local
MONEY_DEFAULTS_CURRENCY=TRY

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Üretim: LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simdibildir
DB_USERNAME=forge
DB_PASSWORD=

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
# Reverb kullanmıyorsanız null bırakın; canlı yayın için ayrı daemon gerekir

SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=simdibildir.com,www.simdibildir.com,simdibildir.test,localhost,localhost:5173

CACHE_STORE=redis
CACHE_PREFIX=

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="destek@simdibildir.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=

# Reverb (isteğe bağlı — gerçek zamanlı özellik açılmadıysa BROADCAST_CONNECTION=null)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=simdibildir.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Cloudflare Turnstile — boş bırakılırsa doğrulama yapılmaz
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Google Maps Embed API (şikâyet detayında pin’li harita). Boşsa OpenStreetMap gösterilir.
GOOGLE_MAPS_API_KEY=

ROLLBAR_TOKEN=

# Tek süper yönetici e-postası (yalnızca bu hesap süper admin olabilir)
SUPER_ADMIN_EMAIL=erkanulker0@gmail.com

# Google AdSense (opsiyonel — ADSENSE_ENABLED=true ve ca-pub kimliği)
ADSENSE_ENABLED=false
ADSENSE_CLIENT=
ADSENSE_SLOT_FEED_SIDEBAR=
ADSENSE_SLOT_FEED_INLINE=
ADSENSE_SLOT_CITY_TOP=
ADSENSE_SLOT_HOME_MID=
