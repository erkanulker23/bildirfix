APP_NAME=BildirFİX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://sorunbildir-v1.test
# TLS (Cloudflare / proxy): üretimde genelde FORCE_HTTPS=true ve APP_URL=https://alanadiniz...
FORCE_HTTPS=false
APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

# Canonical, yapısal veri, OG/Twitter; üretimde SEO_DEFAULT_ROBOTS boş bırakılırsa APP_ENV'e göre belirlenir
SEO_DEFAULT_DESCRIPTION=
SEO_DEFAULT_ROBOTS=
SEO_OG_IMAGE=
SEO_ORG_NAME=
SEO_OG_LOCALE=tr_TR
SEO_FONT_PRECONNECT_HOSTS=https://fonts.bunny.net

# --- Laravel Forge / üretim notları ---
# DEPLOY: composer install --no-dev && npm ci --omit=dev && npm run build
#        php artisan migrate --force && php artisan storage:link && composer run forge-optimize
# SCHEDULER: Forge’da * * * * * php artisan schedule:run
# QUEUE: daemon: php artisan queue:work redis --sleep=3 --tries=3 (veya database)
# SEED: Üretimde db:seed kullanmayın; demo şifreleri DatabaseSeeder içindedir.

LOCALES=tr

IS_DEMO=false
BACKUP_ENABLED=false
BACKUP_DISK=local
MONEY_DEFAULTS_CURRENCY=TRY

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=bildir
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=sorunbildir-v1.test,localhost,localhost:5173

CACHE_STORE=file

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=sorunbildir-v1.test
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Cloudflare Turnstile — boş bırakılırsa doğrulama yapılmaz
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

ROLLBAR_TOKEN=
